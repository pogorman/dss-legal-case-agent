meta {
  name: Chat - Case Query
  type: http
  seq: 2
}

post {
  url: {{containerAppUrl}}/chat
  body: json
  auth: none
}

body:json {
  {
    "messages": [
      {
        "role": "user",
        "content": "Build me a chronological timeline for case 2024-DR-42-0892"
      }
    ]
  }
}

assert {
  res.status: eq 200
  res.body.content: isString
  res.body.tools_called: isDefined
}
