meta {
  name: Chat Completions
  type: http
  seq: 1
}

post {
  url: {{containerAppUrl}}/chat
  body: json
  auth: none
}

body:json {
  {
    "messages": [
      {
        "role": "user",
        "content": "List available cases"
      }
    ]
  }
}

assert {
  res.status: eq 200
  res.body.content: isString
}
