meta {
  name: MCP Call - Get Timeline (Medical)
  type: http
  seq: 6
}

post {
  url: {{containerAppUrl}}/mcp
  body: json
  auth: none
}

body:json {
  {
    "jsonrpc": "2.0",
    "id": 6,
    "method": "tools/call",
    "params": {
      "name": "get_timeline",
      "arguments": {
        "case_id": "{{caseId}}",
        "event_type": "Medical"
      }
    }
  }
}

assert {
  res.status: eq 200
  res.body.result.content: isDefined
}
